# Copy this file to tools/.env and fill in your values.
# tools/.env is gitignored so secrets stay local.

# Base URL of the deployed admin (no trailing slash).
ADMIN_URL=https://theaipicker.com

# Same value as ADMIN_PASSWORD in your Vercel env vars.
# The bridge sends this as `Authorization: Bearer <ADMIN_PASSWORD>`.
ADMIN_PASSWORD=changeme

# Local checkout the bridge writes tasks.md into and runs claude inside.
# Use forward slashes on Windows to avoid escaping.
PROJECT_DIR=C:/Users/John/My Drive/Business Operations/theaipicker-platform

# Optional — defaults to OS hostname, sanitised to A-Z/0-9/._-
# MACHINE_NAME=desktop-bridge

# Optional — polling cadence (ms). Default 30s.
# POLL_INTERVAL_MS=30000

# Optional — heartbeat cadence (ms). Default 60s. The /admin/inbox page
# treats the bridge as online when the latest heartbeat is < 2 minutes old.
# HEARTBEAT_INTERVAL_MS=60000

# Optional — kill claude after this many ms if a job hangs. Default 60min.
# MAX_JOB_MS=3600000

# Optional — override the prompt the bridge passes to `claude -p`.
# CLAUDE_PROMPT=Read tasks.md and execute every task in order. No questions. Make all decisions yourself. Commit and push when done.
